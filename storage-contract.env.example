# =============================================================================
# storage-contract/.env.example
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# NEVER commit .env to GitHub. It is already in .gitignore.
# =============================================================================

# Your MetaMask wallet private key.
# How to get it: MetaMask → click your account icon → Account Details → Export Private Key
# Include the 0x prefix.
# This wallet pays the gas fees for deployment — make sure it has PAS tokens.
# Get testnet PAS from: https://faucet.polkadot.io/?parachain=1111
PRIVATE_KEY=0xYourPrivateKeyHere
