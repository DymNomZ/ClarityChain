# =============================================================================
# dapp/.env.example
# Copy this file to .env.local and fill in your actual values.
#
#   cp .env.example .env.local
#
# Next.js loads environment variables from .env.local automatically.
# NEVER commit .env.local to GitHub. It is already in .gitignore.
# =============================================================================

# The deployed ClarityChain contract address on Polkadot Hub TestNet.
# Update this if the contract is redeployed.
# Current deployment: 0xd8ca14ae4b8c6c497d79d85ab29467bcc4866f84
NEXT_PUBLIC_CONTRACT_ADDRESS=0xd8ca14ae4b8c6c497d79d85ab29467bcc4866f84

# Polkadot Hub TestNet RPC endpoint.
# This is already hardcoded in dapp/app/utils/viem.ts but listed here
# in case you need to switch to a different RPC provider.
NEXT_PUBLIC_RPC_URL=https://services.polkadothub-rpc.com/testnet

# (Optional) Claude API key — only needed if implementing the AI Insights feature.
# Get one from: https://console.anthropic.com
# IMPORTANT: Never expose this to the client. If used, call the Claude API
# from a Next.js API route (/app/api/...), not from a client component.
# ANTHROPIC_API_KEY=sk-ant-yourKeyHere
